# Cortex frontend (live path) — copy to .env.local and fill in.
# With none of these set, the app runs entirely on the local mock store.
# All values are NEXT_PUBLIC_* because storage is signed client-side by the
# user's Privy-managed Sui wallet (no server-held delegate key).

# Privy — login/signup + managed Sui (Tier-2) embedded wallet.
# Create an app at https://dashboard.privy.io and enable Sui under extended chains.
NEXT_PUBLIC_PRIVY_APP_ID=

# Sui network + RPC (gRPC base URL). Defaults to testnet fullnode.
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_RPC=https://fullnode.testnet.sui.io:443

# Deployed cortex Move package + the shared account::Registry object id.
# Publish sui/contract/cortex (`sui client publish`) and paste the ids here.
# Without these, files still upload to Walrus but are not recorded on chain.
NEXT_PUBLIC_CORTEX_PACKAGE_ID=
NEXT_PUBLIC_CORTEX_REGISTRY_ID=

# On-chain admin/executor capability model (cortex::access). The shared
# AccessRegistry id and the ExecutorCap object id, captured from the publish output.
# Used by the app to surface delegation; leave blank until the package is redeployed.
NEXT_PUBLIC_CORTEX_ACCESS_REGISTRY=
NEXT_PUBLIC_CORTEX_EXECUTOR_CAP=

# The Sui address of the MCP service wallet (its delegate keypair's address) that the user authorizes from Integrations → MCP to grant on-chain admin-delegate access.
NEXT_PUBLIC_CORTEX_MCP_ADDRESS=

# How many Walrus epochs to store blobs for.
NEXT_PUBLIC_WALRUS_EPOCHS=5
# Walrus Harbor fast path — upload relay (fast writes) + aggregator (fast reads).
# Defaults are the public testnet endpoints; override for mainnet or a private relay.
NEXT_PUBLIC_WALRUS_UPLOAD_RELAY=https://upload-relay.testnet.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space

# Seal key server object ids (comma-separated) + threshold. When empty, blobs are
# stored unencrypted; when set, files are Seal-encrypted before upload.
NEXT_PUBLIC_SEAL_SERVER_IDS=
NEXT_PUBLIC_SEAL_THRESHOLD=1

# Walrus Memory (MemWal) relayer. Per-user account id + delegate key are
# provisioned in-browser and kept in a per-user keystore, not in env.
NEXT_PUBLIC_MEMWAL_SERVER_URL=https://relayer.memwal.ai
# Walrus Memory contract ids (memory.walrus.xyz) — required to auto-provision a
# per-user memory account so remember/recall persist to Walrus.
NEXT_PUBLIC_MEMWAL_PACKAGE_ID=
NEXT_PUBLIC_MEMWAL_REGISTRY_ID=

# Model provider keys — SERVER-ONLY (no NEXT_PUBLIC prefix), used by the /api
# routes. Set any subset; a model whose provider key is absent falls back to a
# local deterministic response.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=

# Cortex MCP server (mcp/server.ts) outbound webhook — SERVER-ONLY. When set, the
# `service_notify` MCP tool POSTs memory-event payloads here (Slack/Discord/Zapier
# incoming webhook). When unset, `service_notify` returns an actionable error.
CORTEX_WEBHOOK_URL=

# Cortex MCP server on-chain access model — SERVER-ONLY. The shared
# cortex::access::AccessRegistry id and the ExecutorCap object id transferred to the
# MCP wallet at deploy. Surfaced by the `wallet_info` tool; required for the server
# to act as a gated executor over user accounts.
CORTEX_ACCESS_REGISTRY=
CORTEX_EXECUTOR_CAP=
