# Cortex MCP server env - copy to .env and fill in (.env is gitignored).
# Loaded by server.ts on startup; point elsewhere with CORTEX_ENV_FILE.
# With none of these set, the MCP runs on the deterministic local mock store.

CORTEX_NAMESPACE=personal

# Sui network + RPC the MCP reads/writes through.
CORTEX_SUI_RPC=https://fullnode.mainnet.sui.io:443
CORTEX_SUI_NETWORK=mainnet

# Walrus publisher (writes) + aggregator (reads).
CORTEX_WALRUS_PUBLISHER=
CORTEX_WALRUS_AGGREGATOR=
CORTEX_WALRUS_EPOCHS=5

# Deployed cortex Move package id + on-chain access model (cortex::access). Captured
# from the publish output (Published.toml / published.json). CORTEX_PACKAGE_ID is the
# package the MCP makes access/workspace calls against; CORTEX_EXECUTOR_CAP must be
# owned by the MCP wallet below for it to act as the gated executor.
CORTEX_PACKAGE_ID=
CORTEX_ACCESS_REGISTRY=
CORTEX_EXECUTOR_CAP=

# Dedicated MCP service wallet private key (suiprivkey...). Its address is the one
# users authorize from Integrations -> MCP, and it must hold the ExecutorCap. Needs
# native gas (mainnet SUI) to sign executor transactions.
CORTEX_DELEGATE_KEY=

# Agent workspace: pin an explicit Workspace object id (wins), or give the owner's
# Sui address so the MCP resolves the id the user created from the Agents view.
CORTEX_WORKSPACE_ID=
CORTEX_USER_ADDRESS=

# Walrus Memory (MemWal) relayer URL + API key for memory reads/writes.
CORTEX_MEMWAL_URL=
MEMWAL_API_KEY=

# Seal threshold encryption. Leave SERVER_IDS empty to use the SDK's allowlisted
# key servers; set them (comma-separated KeyServer object ids) to pin specific ones.
CORTEX_SEAL_POLICY_OBJECT=
SEAL_SERVER_IDS=
SEAL_THRESHOLD=1

# Server-side reasoning provider for extraction/consolidation/agent+loop steps.
# Leave the key blank to fall back to deterministic heuristics.
CORTEX_MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Outbound webhook the service_notify tool POSTs memory events to (optional).
CORTEX_WEBHOOK_URL=
