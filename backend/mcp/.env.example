# Cortex MCP server env - copy to .env and fill in (.env is gitignored).
# Loaded by server.ts on startup; point elsewhere with CORTEX_ENV_FILE.
# Dual-network: CORTEX_SUI_NETWORK selects which set of _MAINNET / _TESTNET slots
# is used. Reused values (delegate wallet, model keys) stay untagged. With none
# set, the MCP runs on the deterministic local mock store.

CORTEX_NAMESPACE=personal

# Active network for this MCP process (testnet | mainnet).
CORTEX_SUI_NETWORK=testnet

# Walrus epochs (network-agnostic).
CORTEX_WALRUS_EPOCHS=5

# Reused MCP service wallet (suiprivkey...). Holds the ExecutorCap on both networks;
# its address is the one users authorize from Integrations -> MCP. Needs native gas.
CORTEX_DELEGATE_KEY=

# Agent workspace: pin an explicit Workspace object id, or give the owner address.
CORTEX_WORKSPACE_ID=
CORTEX_USER_ADDRESS=

# Server-side reasoning provider (network-agnostic). "anthropic" | "google".
CORTEX_MODEL_PROVIDER=google
CORTEX_MODEL_CHAT=gemini-2.5-flash
CORTEX_MODEL_EXTRACT=gemini-2.5-flash
GEMINI_API_KEY=

# ============================== MAINNET ==============================
CORTEX_SUI_RPC_MAINNET=https://fullnode.mainnet.sui.io:443
CORTEX_WALRUS_PUBLISHER_MAINNET=https://publisher.walrus-mainnet.walrus.space
CORTEX_WALRUS_AGGREGATOR_MAINNET=https://aggregator.walrus-mainnet.walrus.space
CORTEX_PACKAGE_ID_MAINNET=
CORTEX_ACCESS_REGISTRY_MAINNET=
CORTEX_EXECUTOR_CAP_MAINNET=
MEMWAL_SERVER_URL_MAINNET=
MEMWAL_ACCOUNT_ID_MAINNET=
MEMWAL_PRIVATE_KEY_MAINNET=
SEAL_SERVER_IDS_MAINNET=
SEAL_THRESHOLD_MAINNET=1
SEAL_POLICY_OBJECT_MAINNET=

# ============================== TESTNET ==============================
CORTEX_SUI_RPC_TESTNET=https://fullnode.testnet.sui.io:443
CORTEX_WALRUS_PUBLISHER_TESTNET=https://publisher.walrus-testnet.walrus.space
CORTEX_WALRUS_AGGREGATOR_TESTNET=https://aggregator.walrus-testnet.walrus.space
CORTEX_PACKAGE_ID_TESTNET=
CORTEX_ACCESS_REGISTRY_TESTNET=
CORTEX_EXECUTOR_CAP_TESTNET=
MEMWAL_SERVER_URL_TESTNET=
MEMWAL_ACCOUNT_ID_TESTNET=
MEMWAL_PRIVATE_KEY_TESTNET=
# Testnet Seal: Ruby Nodes open-mode key server (free, no API key).
SEAL_SERVER_IDS_TESTNET=0x6068c0acb197dddbacd4746a9de7f025b2ed5a5b6c1b1ab44dade4426d141da2
SEAL_THRESHOLD_TESTNET=1
SEAL_POLICY_OBJECT_TESTNET=
