# Cortex  -  copy to .env.local and fill in.
# With none of these set, the app runs entirely on the local mock store.
# NEXT_PUBLIC_* values are inlined into the browser bundle (the live storage path
# is signed client-side by the user's Privy-managed Sui wallet). Variables without
# the NEXT_PUBLIC_ prefix are SERVER-ONLY (read by /api routes and the MCP server)
# and must never be exposed to the client.

# Documentation site URL. Used by the landing nav/footer and the in-app Docs
# link. Defaults to the live docs at https://docs.usecortexai.xyz/.
# Override this locally only if you want to point at a different docs instance.
NEXT_PUBLIC_DOCS_URL=https://docs.usecortexai.xyz/

# Privy  -  login/signup + managed Sui (Tier-2) embedded wallet.
# Create an app at https://dashboard.privy.io and enable Sui under extended chains.
NEXT_PUBLIC_PRIVY_APP_ID=
# Privy app secret  -  SERVER-ONLY, optional. Only needed if you add a server route
# that verifies Privy auth tokens; the client login flow does not require it.
PRIVY_APP_SECRET=

# Sui network + RPC (gRPC base URL). Defaults to testnet fullnode.
NEXT_PUBLIC_SUI_NETWORK=testnet
NEXT_PUBLIC_SUI_RPC=https://fullnode.testnet.sui.io:443
# Sui GraphQL endpoint, used for reads alongside gRPC. Defaults per network.
NEXT_PUBLIC_SUI_GRAPHQL=https://graphql.testnet.sui.io/graphql

# Deployed cortex Move package + the shared account::Registry object id.
# Publish sui/contract/cortex (`sui client publish`) and paste the ids here.
# Without these, files still upload to Walrus but are not recorded on chain.
NEXT_PUBLIC_CORTEX_PACKAGE_ID=
NEXT_PUBLIC_CORTEX_REGISTRY_ID=

# Opt-in switch ("1" to enable) for the on-chain cortex::memory module. Off by
# default: until the upgraded package carrying the memory module is published, the
# live memory flow stays entirely on MemWal. When "1", remember/allMemories also
# use the on-chain MemoryEntry path.
NEXT_PUBLIC_CORTEX_MEMORY_MODULE=

# Package version whose code is CALLED for the cortex::memory module. Set this to the
# UPGRADED package id when the memory module was added in an upgrade (new modules only
# exist at the upgraded id; type tags keep NEXT_PUBLIC_CORTEX_PACKAGE_ID). Leave blank
# if memory shipped in the original publish.
NEXT_PUBLIC_CORTEX_MEMORY_PACKAGE_ID_TESTNET=
NEXT_PUBLIC_CORTEX_MEMORY_PACKAGE_ID_MAINNET=

# On-chain admin/executor capability model (cortex::access). The shared
# AccessRegistry id and the ExecutorCap object id, captured from the publish output.
# Used by the app to surface delegation; leave blank until the package is redeployed.
NEXT_PUBLIC_CORTEX_ACCESS_REGISTRY=
NEXT_PUBLIC_CORTEX_EXECUTOR_CAP=

# Optional fallback for the shared agent Workspace object id. Normally the app creates
# the Workspace from the Agents view and records its id in the user's on-chain account
# (so no env is needed); set this only to pin a specific Workspace for every browser.
NEXT_PUBLIC_CORTEX_WORKSPACE_ID=

# The Sui address of the MCP service wallet (its delegate keypair's address) that the user authorizes from Integrations → MCP to grant on-chain admin-delegate access.
NEXT_PUBLIC_CORTEX_MCP_ADDRESS=

# The MCP's MemWal delegate PUBLIC key (the private key stays on the server) so the MCP can read your memory.
NEXT_PUBLIC_CORTEX_MCP_MEMWAL_PUBKEY=

# Public URL of a HOSTED Cortex MCP server (HTTP transport), if you run one. Leave
# empty: with no hosted endpoint, Integrations documents the local stdio setup
# (`claude mcp add cortex -- pnpm --filter cortex-mcp start`). Set this only once a
# hosted MCP endpoint is deployed.
NEXT_PUBLIC_CORTEX_MCP_URL=

# How many Walrus epochs to store blobs for.
NEXT_PUBLIC_WALRUS_EPOCHS=5
# Walrus Harbor fast path  -  upload relay (fast writes) + aggregator (fast reads).
# Defaults are the public testnet endpoints; override for mainnet or a private relay.
NEXT_PUBLIC_WALRUS_UPLOAD_RELAY=https://upload-relay.testnet.walrus.space
NEXT_PUBLIC_WALRUS_AGGREGATOR=https://aggregator.walrus-testnet.walrus.space
# WAL coin type used to read the wallet's WAL balance. Defaults per network.
NEXT_PUBLIC_WAL_COIN_TYPE=0x8270feb7375eee355e64fdb69c50abb6b5f9393a722883c1cf45f8e26048810a::wal::WAL

# Seal key-server object ids (comma-separated) + threshold. This is the SWITCH for
# Seal threshold encryption: when SERVER_IDS is empty, session/memory blobs fall back
# to wallet-derived AES-GCM (and legacy untagged blobs still read as AES); when set,
# blobs are Seal-encrypted (SEAL_TAG) under the user's owner identity instead.
# Get testnet key-server object ids from Mysten's published Seal testnet servers
# (see the @mysten/seal README) or by running `getAllowlistedKeyServers("testnet")`
# and copying the objectIds. THRESHOLD is how many of those servers must return a
# share to decrypt: 1 = any single server; must be >= 1 and <= the number of ids.
NEXT_PUBLIC_SEAL_SERVER_IDS=
NEXT_PUBLIC_SEAL_THRESHOLD=1

# Walrus Memory (MemWal) relayer. Per-user account id + delegate key are
# provisioned in-browser and kept in a per-user keystore, not in env.
NEXT_PUBLIC_MEMWAL_SERVER_URL=https://relayer.memwal.ai
# Walrus Memory contract ids (memory.walrus.xyz)  -  required to auto-provision a
# per-user memory account so remember/recall persist to Walrus.
NEXT_PUBLIC_MEMWAL_PACKAGE_ID=
NEXT_PUBLIC_MEMWAL_REGISTRY_ID=

# SuiNS usernames (Settings → claim a username). The frontend resolves handles
# under this parent domain; defaults to cortex.sui.
NEXT_PUBLIC_CORTEX_SUINS_PARENT=cortex.sui
# SERVER-ONLY (used by /api/suins/claim to mint a leaf subname under the parent):
# the object id of the parent SuiNS domain NFT, and the Bech32 private key of the
# wallet that holds that domain (it signs the subname mint).
CORTEX_SUINS_PARENT_NFT_ID=
CORTEX_SUINS_SIGNER_KEY=

# Gas station  -  SERVER-ONLY (used by /api/gas). On testnet the executor wallet
# sponsors every user transaction: a fresh Privy embedded wallet holds no SUI/WAL,
# so /api/gas tops it up from this wallet on sign-in (gas for on-chain writes plus
# WAL for Walrus storage). Set to the Bech32 `suiprivkey...` of the executor wallet
# (the address in NEXT_PUBLIC_CORTEX_MCP_ADDRESS). It must hold testnet SUI AND WAL.
# Unset -> /api/gas returns 503 and the app runs unfunded (writes will fail).
CORTEX_SPONSOR_KEY=

# Model provider keys  -  SERVER-ONLY (no NEXT_PUBLIC prefix), used by the /api
# routes. Set any subset; a model whose provider key is absent falls back to a
# local deterministic response. GEMINI_API_KEY also powers /api/transcribe (voice).
# ANTHROPIC_API_KEY and GEMINI_API_KEY ALSO power the MCP server runtime
# reasoning (extraction, consolidation, agent + loop steps). CORTEX_MODEL_PROVIDER
# pins which one the core uses ("anthropic" | "google"); unset, it infers from
# whichever key is present, so a Gemini-only deploy needs only GEMINI_API_KEY.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
XAI_API_KEY=
GEMINI_API_KEY=
CORTEX_MODEL_PROVIDER=

# Cortex MCP server (mcp/server.ts) outbound webhook  -  SERVER-ONLY. When set, the
# `service_notify` MCP tool POSTs memory-event payloads here (Slack/Discord/Zapier
# incoming webhook). When unset, `service_notify` returns an actionable error.
CORTEX_WEBHOOK_URL=

# Cortex MCP server wallet  -  SERVER-ONLY. The Ed25519/Bech32 private key of the MCP
# service wallet (its delegate identity). The server signs executor-gated on-chain
# calls with this; its address is the one users authorize from Integrations → MCP
# (and the value of NEXT_PUBLIC_CORTEX_MCP_ADDRESS).
CORTEX_DELEGATE_KEY=
# MemWal relayer API key for the MCP server's memory reads/writes  -  SERVER-ONLY.
MEMWAL_API_KEY=

# Cortex MCP server on-chain access model  -  SERVER-ONLY. The shared
# cortex::access::AccessRegistry id and the ExecutorCap object id transferred to the
# MCP wallet at deploy. Surfaced by the `wallet_info` tool; required for the server
# to act as a gated executor over user accounts.
CORTEX_ACCESS_REGISTRY=
CORTEX_EXECUTOR_CAP=

# The MCP service wallet's Sui private key (suiprivkey...)  -  SERVER-ONLY. This is the
# delegate the server signs executor writes with and uses to decrypt workspace blobs as
# an authorized delegate. Its address must be granted on the user's account/workspace
# (done from Integrations -> MCP "Authorize MCP").
CORTEX_DELEGATE_KEY=

# Agent workspace  -  the shared cortex::workspace::Workspace object the MCP reads/writes
# as the authorized executor. Two ways to point the MCP at one:
#   1) CORTEX_WORKSPACE_ID  -  pin an explicit Workspace object id (always wins), or
#   2) CORTEX_USER_ADDRESS  -  the owner's Sui address; the MCP reads the id the user
#      created from the app's Agents view (saved in their on-chain account setting
#      "agents:workspace"). Requires the user to have authorized this MCP as a delegate.
# Without either, the MCP's agent tools report the board is unconfigured.
CORTEX_WORKSPACE_ID=
CORTEX_USER_ADDRESS=

# Seal key-server object ids (comma-separated) + threshold the MCP/core uses to
# encrypt + decrypt blobs as an authorized delegate. SERVER-ONLY. When empty, the
# core falls back to the SDK's allowlisted testnet servers (and a no-op Seal in mock
# mode); when set, these pin the exact key servers. Get testnet ids from Mysten's
# published Seal testnet servers (@mysten/seal README) or `getAllowlistedKeyServers`.
# THRESHOLD: how many servers must return a share to decrypt (>= 1, <= number of ids).
SEAL_SERVER_IDS=
SEAL_THRESHOLD=1
