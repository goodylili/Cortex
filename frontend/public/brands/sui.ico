<script>
window.onWeglotReady = function(callback) {
    if (window.__weglotReady) {
      callback();
    } else {
      window.addEventListener('weglotReady', callback, { once: true });
    }
  };

  function loadWeglot() {
    var s = document.createElement('script');
    s.src = 'https://cdn.weglot.com/weglot.min.js';
    s.onload = function() {
      Weglot.initialize({
        api_key: 'wg_21979a474a72deff1ecb6ebc4ba9edb93',
        extra_definitions: [
          { selector: '[global-target]', attribute: 'data-weglot-text', type: 1 },
          { selector: '[global="scrumble"]', attribute: 'data-weglot-text', type: 1 },
          { selector: '[global="shuffleHover"]', attribute: 'data-weglot-text', type: 1 }
        ],
        excluded_elements: ['[aria-hidden="true"]', '.char', '.word', '.line']
      });
      window.__weglotReady = true;
      window.dispatchEvent(new CustomEvent('weglotReady'));
    };
    document.head.appendChild(s);
  }
  
  if (document.readyState === 'complete') {
    setTimeout(loadWeglot, 100);
  } else {
    window.addEventListener('load', function() {
      setTimeout(loadWeglot, 100);
    });
  }


  
  (function() {
    var src = window.location.host.includes("webflow.io")
      ? "https://slater.app/17378.js"
      : "https://assets.slater.app/slater/17378.js?v=1.0";
    var s = document.createElement('script');
    s.src = src;
    s.type = 'module';
    s.defer = true;
    document.head.appendChild(s);
  })();
</script>




<script>
const forms = document.querySelectorAll('#newsletter, #newsletter-mob');
const navbarToggles = document.querySelectorAll('.navbar-dd_toggle');
const resetButtons = document.querySelectorAll('.hm_back-button, .hamburger-menu');
forms.forEach(form => {
  const input = form.querySelector('.hs-input');
  const submitBtn = form.querySelector('.hs-submit');
  const errorMsg = form.querySelector('.hs_error-message');
  const successMsg = form.querySelector('.hs_success-message');
  const parentBlock = submitBtn.closest('.hs-submit_block');

  function isValidEmail(email) {
    const regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    return regex.test(email);
  }

  submitBtn.addEventListener('click', function (e) {
    
    const email = input.value.trim();
    if (!isValidEmail(email)) {
      e.preventDefault();
      errorMsg.style.display = 'block';
      submitBtn.classList.add('disable');
      successMsg.style.display = 'none';
      if (parentBlock) {
        parentBlock.classList.add('disable');
      }
    }
  });

  input.addEventListener('input', function () {
    errorMsg.style.display = 'none';
    successMsg.style.display = 'none';
    submitBtn.classList.remove('disable');
    submitBtn.classList.remove('success');
    if (parentBlock) {
      parentBlock.classList.remove('success');
      parentBlock.classList.remove('disable');
    }
  });

  const observer = new MutationObserver(function (mutations) {
    mutations.forEach(function (mutation) {
      mutation.addedNodes.forEach(function (node) {
        if (node.nodeType === 1) {
          const text = node.textContent.trim();
          if (text.includes('Thanks for subscribing')) {
            node.style.display = 'none';
            submitBtn.classList.add('success');
            if (parentBlock) {
              parentBlock.classList.add('success');
            }
            successMsg.style.display = 'block';
            errorMsg.style.display = 'none';
            submitBtn.classList.remove('disable');
            if (parentBlock) {
              parentBlock.classList.remove('disable');
            }
          }
        }
      });
    });
  });

  observer.observe(form, { childList: true, subtree: true });
});
  
function resetForm(form) {
  const input = form.querySelector('.hs-input');
  const submitBtn = form.querySelector('.hs-submit');
  const errorMsg = form.querySelector('.hs_error-message');
  const successMsg = form.querySelector('.hs_success-message');
  const parentBlock = submitBtn.closest('.hs-submit_block');
  const checkbox = form.querySelector('.hs-checkbox_input');

  if (input) input.value = '';
  if (checkbox) checkbox.checked = false;
  if (errorMsg) errorMsg.style.display = 'none';
  if (successMsg) successMsg.style.display = 'none';

  if (submitBtn) {
    submitBtn.classList.remove('disable', 'success');
    if (parentBlock) parentBlock.classList.remove('disable', 'success');
  }
}
  
  
function resetAllForms() {
  forms.forEach(form => resetForm(form));
}

navbarToggles.forEach(toggle => {
  toggle.addEventListener('mouseenter', resetAllForms);
});
  
resetButtons.forEach(button => {
  button.addEventListener('click', resetAllForms);
});
</script>

<!-- buttondown & mailchimp -->
<script>
document.addEventListener('DOMContentLoaded', () => {
  const forms = document.querySelectorAll('#dev-newsletter-2, #dev-newsletter-mob-2, #newsletter-2, #newsletter-mob-2'); 
  const navbarToggles = document.querySelectorAll('.navbar-dd_toggle');
  const resetButtons = document.querySelectorAll('.hm_back-button, .hamburger-menu');

  forms.forEach(form => {
    const input = form.querySelector('.hs-input');
    const submitBtn = form.querySelector('.hs-submit');
    const errorMsg = form.querySelector('.hs_error-message');
    const successMsg = form.querySelector('.hs_success-message');
    const parentBlock = submitBtn.closest('.hs-submit_block');

    function isValidEmail(email) {
      const regex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      return regex.test(email);
    }

    function showSuccess() {
      submitBtn.classList.add('success');
      if (parentBlock) parentBlock.classList.add('success');
      successMsg.style.display = 'block';
      errorMsg.style.display = 'none';
      submitBtn.classList.remove('disable');
      if (parentBlock) parentBlock.classList.remove('disable');
    }

    function showError() {
      errorMsg.style.display = 'block';
      successMsg.style.display = 'none';
      submitBtn.classList.add('disable');
      if (parentBlock) parentBlock.classList.add('disable');
    }

    async function ajaxSubmit() {
      try {
        const formData = new FormData(form);
        await fetch(form.action, {
          method: (form.method || 'POST').toUpperCase(),
          body: formData,
          mode: 'no-cors'
        });
        showSuccess();
      } catch (err) {
        showError();
      }
    }

    form.addEventListener('submit', function(e) {
      e.preventDefault();
      const email = input.value.trim();
      if (!isValidEmail(email)) {
        showError();
        return;
      }
      ajaxSubmit();
    });

    input.addEventListener('input', function () {
      errorMsg.style.display = 'none';
      successMsg.style.display = 'none';
      submitBtn.classList.remove('disable');
      submitBtn.classList.remove('success');
      if (parentBlock) {
        parentBlock.classList.remove('success');
        parentBlock.classList.remove('disable');
      }
    });

    const observer = new MutationObserver(function (mutations) {
      mutations.forEach(function (mutation) {
        mutation.addedNodes.forEach(function (node) {
          if (node.nodeType === 1) {
            const text = node.textContent.trim();
            if (text.includes('Thanks for subscribing')) {
              node.style.display = 'none';
              showSuccess();
            }
          }
        });
      });
    });

    observer.observe(form, { childList: true, subtree: true });
  });

  function resetForm(form) {
    const input = form.querySelector('.hs-input');
    const submitBtn = form.querySelector('.hs-submit');
    const errorMsg = form.querySelector('.hs_error-message');
    const successMsg = form.querySelector('.hs_success-message');
    const parentBlock = submitBtn.closest('.hs-submit_block');
    const checkbox = form.querySelector('.hs-checkbox_input');

    if (input) input.value = '';
    if (checkbox) checkbox.checked = false;
    if (errorMsg) errorMsg.style.display = 'none';
    if (successMsg) successMsg.style.display = 'none';

    if (submitBtn) {
      submitBtn.classList.remove('disable', 'success');
      if (parentBlock) parentBlock.classList.remove('disable', 'success');
    }
  }

  function resetAllForms() {
    forms.forEach(form => resetForm(form));
  }

  navbarToggles.forEach(toggle => {
    toggle.addEventListener('mouseenter', resetAllForms);
  });

  resetButtons.forEach(button => {
    button.addEventListener('click', resetAllForms);
  });

});
</script>

<style>
  .hs-submit.is-waiting {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hs-submit.is-waiting::after {
    content: '.';
    flex: none;
    width: 0.9em;
    text-align: left;
    animation: hsDots 1.2s infinite;
  }
  @keyframes hsDots {
    0%, 33%   { content: '.'; }
    34%, 66%  { content: '..'; }
    67%, 100% { content: '...'; }
  }
</style>

<script>
(function () {
  const EMAIL = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const mq = window.matchMedia('(min-width: 768px)');

  let cleanups = [];

  const setup = () => {
    const forms = document.querySelectorAll('form.hs-form_block');
    if (!forms.length) return;

    const restores = [];

    forms.forEach((form) => {
      const button = form.querySelector('.hs-submit');
      const input = form.querySelector('.hs-input');
      if (!button || !input) return;

      const success = form.querySelector('.hs_success-message');
      const error = form.querySelector('.hs_error-message');
      const original = button.textContent.trim();
      const waitText = button.getAttribute('data-wait-text') || 'Please wait';
      const doneText = button.getAttribute('data-done-text') || 'Subscribed';

      let pending = false;
      let fallback;
      let obs;

      const visible = (el) =>
        el && el.style.display !== 'none' && getComputedStyle(el).display !== 'none';

      const restore = () => {
        pending = false;
        clearTimeout(fallback);
        button.classList.remove('is-waiting');
        button.style.minWidth = '';
        button.disabled = false;
        button.textContent = original;
      };

      const finish = () => {
        if (!pending) return;
        if (visible(success)) {
          pending = false;
          clearTimeout(fallback);
          button.classList.remove('is-waiting');
          button.style.minWidth = '';
          button.disabled = false;
          button.textContent = doneText;
        } else if (visible(error)) {
          restore();
        }
      };

      if (success || error) {
        obs = new MutationObserver(finish);
        [success, error].forEach(
          (el) => el && obs.observe(el, { attributes: true, attributeFilter: ['style', 'class'] })
        );
      }

      const onSubmit = () => {
        if (pending) return;
        if (!EMAIL.test(input.value.trim())) return;
        pending = true;
        button.style.minWidth = button.offsetWidth + 'px';
        button.textContent = waitText;
        button.classList.add('is-waiting');
        requestAnimationFrame(() => { button.disabled = true; });
        clearTimeout(fallback);
        fallback = setTimeout(restore, 10000);
      };

      form.addEventListener('submit', onSubmit);
      input.addEventListener('input', restore);

      restores.push(restore);
      cleanups.push(() => {
        form.removeEventListener('submit', onSubmit);
        input.removeEventListener('input', restore);
        if (obs) obs.disconnect();
        restore();
      });
    });

    const restoreAll = () => restores.forEach((fn) => fn());
    const toggles = document.querySelectorAll('.navbar-dd_toggle');
    const resetBtns = document.querySelectorAll('.hm_back-button, .hamburger-menu');

    toggles.forEach((el) => el.addEventListener('mouseenter', restoreAll));
    resetBtns.forEach((el) => el.addEventListener('click', restoreAll));

    cleanups.push(() => {
      toggles.forEach((el) => el.removeEventListener('mouseenter', restoreAll));
      resetBtns.forEach((el) => el.removeEventListener('click', restoreAll));
    });
  };

  const teardown = () => {
    cleanups.forEach((fn) => fn());
    cleanups = [];
  };

  const apply = () => {
    teardown();
    if (mq.matches) setup();
  };

  document.addEventListener('DOMContentLoaded', () => {
    apply();
    mq.addEventListener('change', apply);
  });
})();
</script><script src="https://hubspotonwebflow.com/assets/js/form-124.js" type="text/javascript" integrity="sha384-bjyNIOqAKScdeQ3THsDZLGagNN56B4X2Auu9YZIGu+tA/PlggMk4jbWruG/P6zYj" crossorigin="anonymous"></script></body></html>