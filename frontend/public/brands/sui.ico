[data-button-hover] {
  overflow: hidden;
  background-color: #298DFF;
  transition: background-color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

[data-button-hover]:hover {
  background-color: #fff;
}

[data-button-hover] [global-target] {
  transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

[data-button-hover]:hover [global-target] {
  color: #000;
}

[data-button-hover] svg {
  overflow: hidden;
  transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

[data-button-hover]:hover svg {
  color: #000;
}

[data-button-hover] svg path:nth-of-type(1) {
  transition: translate 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  translate: 0 0;
}

[data-button-hover] svg path:nth-of-type(2) {
  transition: translate 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  translate: -100% 0;
}

[data-button-hover]:hover svg path:nth-of-type(1) {
  translate: 100% 0;
}

[data-button-hover]:hover svg path:nth-of-type(2) {
  translate: 0 0;
}

[data-button-hover] svg rect {
  fill: #298DFF;
  transform-origin: center bottom;
  transform: scaleY(0);
  transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

[data-button-hover]:hover svg rect {
  transform: scaleY(1);
}

[data-btn] {

  cursor: pointer;
  transition: color 0.4s cubic-bezier(0.16, 1, 0.3, 1);
}

[data-btn]:hover {

  color: #298DFF;
  
}

.resource_list-item {
  position: relative;
  background-color: transparent;
}

.resource_list-item::before {
  content: '';
  position: absolute;
  inset: 0;
  background-color: currentColor;
  opacity: 0;
  z-index: 0;
  transition: opacity 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
  pointer-events: none;
}

.resource_list-item:hover::before {
  opacity: 1;
}

.resource_list-item > * {
  position: relative;
  z-index: 1;
}

.resource-list_icon {
  overflow: visible;
  transition: width 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.resource_list-item:hover .resource-list_icon {
  width: 3.5em;
}

.resource-list_icon-arrow {
  background-color: #298dff;
  opacity: 0;
  overflow: hidden;
  transition: opacity 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.resource-list_icon-arrow path {
  transform: translateX(-1.5em);
  transition: transform 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.resource_list-item:hover .resource-list_icon-arrow {
  opacity: 1;
}

.resource_list-item:hover .resource-list_icon-arrow path {
  transform: translateX(0px);
}



.resource_list-item .h3-24px {
  transition: color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.resource_list-item[data-wf--resource_component--variant="dark"] .h3-24px {
  color: #67707E;
}

.resource_list-item[data-wf--resource_component--variant="dark"]:hover .h3-24px {
  color: #FFFFFF;
}

.resource_list-item:not([data-wf--resource_component--variant="dark"]) .h3-24px {
  color: #A1A7B2;
}

.resource_list-item:not([data-wf--resource_component--variant="dark"]):hover .h3-24px {
  color: #000000;
}

  .resource_list-item[data-wf--resource_component--variant="dark"] .resource-list_icon {
  color: #67707E;
}

.resource_list-item:not([data-wf--resource_component--variant="dark"]) .resource-list_icon {
  color: #A1A7B2;
}

.resource-list_icon {
  transition: width 0.3s cubic-bezier(0.25, 0.1, 0.25, 1),
              color 0.3s cubic-bezier(0.25, 0.1, 0.25, 1);
}

.resource_list-item:hover .resource-list_icon {
  width: 3.5em;
  color: #298DFF;
}
